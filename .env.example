# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a git — solo este archivo de ejemplo

VITE_ADMIN_PIN=XXXX
VITE_VAPID_PUB=<clave-publica-VAPID>
VITE_FB_API_KEY=<firebase-api-key>
VITE_FB_AUTH_DOMAIN=<proyecto>.firebaseapp.com
VITE_FB_DATABASE_URL=https://<proyecto>-default-rtdb.europe-west1.firebasedatabase.app
VITE_FB_PROJECT_ID=<proyecto>
VITE_FB_STORAGE_BUCKET=<proyecto>.firebasestorage.app
VITE_FB_MESSAGING_SENDER_ID=<sender-id>
VITE_FB_APP_ID=<app-id>

# Sentry error tracking (optional)
VITE_SENTRY_DSN=

# Push notifications (server only)
VAPID_PUBLIC=
VAPID_PRIVATE=
PUSH_API_KEY=
PUSH_ALLOWED_ORIGIN=
FIREBASE_DB_AUTH_TOKEN=
