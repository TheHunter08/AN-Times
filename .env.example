# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a git — solo este archivo de ejemplo

# ── Supabase ───────────────────────────────────────────────────────────────────
# URL y clave anon (Settings > API en tu proyecto Supabase)
VITE_SB_URL=https://<project-id>.supabase.co
VITE_SB_ANON=<anon-public-key>

# ── Admin ──────────────────────────────────────────────────────────────────────
# PIN del administrador. Si no se configura, se genera uno aleatorio en el primer acceso.
VITE_ADMIN_PIN=XXXX

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VITE_VAPID_PUB=<clave-publica-VAPID>

# Solo en servidor (no VITE_) — NO se incluyen en el bundle del frontend
VAPID_PUBLIC=<clave-publica-VAPID>
VAPID_PRIVATE=<clave-privada-VAPID>

# ── Seguridad push ────────────────────────────────────────────────────────────
# Token que protege el endpoint /api/sendpush contra uso no autorizado
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PUSH_SECRET=<token-aleatorio-32-bytes>

# Solo peticiones desde este origen pueden llamar a /api/sendpush
PUSH_ALLOWED_ORIGIN=https://your-app.vercel.app

# ── Monitoring (opcional) ─────────────────────────────────────────────────────
# DSN de Sentry para captura de errores en producción
VITE_SENTRY_DSN=
