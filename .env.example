# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a git — solo este archivo de ejemplo

# ── Supabase ───────────────────────────────────────────────────────────────────
# URL y clave anon (Settings > API en tu proyecto Supabase)
VITE_SB_URL=https://<project-id>.supabase.co
VITE_SB_ANON=<anon-public-key>

# ── Admin ──────────────────────────────────────────────────────────────────────
# PIN del administrador. Si no se configura, se genera uno aleatorio en el primer acceso.
VITE_ADMIN_PIN=XXXX

# Opcional — solo si vas a usar la Admin API con service_role (migraciones,
# /api/pin-login escribiendo auth_id una vez RLS esté activo). NUNCA exponer
# con prefijo VITE_. Dashboard → Settings → API → Project API keys → service_role.
SB_SERVICE_KEY=

# Legacy JWT Secret del proyecto (Settings → API → JWT Settings). Firma los
# tokens que /api/pin-login emite para que un login por PIN también obtenga un
# auth.uid() real, sin pasar por el login hospedado de Supabase Auth — necesario
# para que las políticas RLS de supabase/policies_auth.sql funcionen con
# empleados que fichan por PIN (la mayoría). Si el proyecto ya migró del todo a
# claves de firma asimétricas (JWKS/ES256) y no conserva este secreto legacy,
# este endpoint necesita reescribirse usando la Admin API de Supabase en su lugar.
SUPABASE_JWT_SECRET=

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VITE_VAPID_PUB=<clave-publica-VAPID>

# Solo en servidor (no VITE_) — NO se incluyen en el bundle del frontend
VAPID_PUBLIC=<clave-publica-VAPID>
VAPID_PRIVATE=<clave-privada-VAPID>

# ── Seguridad push ────────────────────────────────────────────────────────────
# Token que protege el endpoint /api/sendpush contra uso no autorizado
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PUSH_SECRET=<token-aleatorio-32-bytes>

# Solo peticiones desde este origen pueden llamar a /api/sendpush
PUSH_ALLOWED_ORIGIN=https://your-app.vercel.app

# ── Cron de recordatorios ─────────────────────────────────────────────────────
# Token para poder invocar /api/cron-reminders manualmente (ej: Insomnia/Postman)
# Las invocaciones automáticas de Vercel Cron no lo necesitan.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=<token-aleatorio>

# ── WhatsApp (opcional) ────────────────────────────────────────────────────────
# Meta for Developers → tu app → WhatsApp → Getting Started / System User
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Cadena que tú eliges (ej: un UUID) — se configura también en Meta al dar de
# alta el webhook de /api/whatsapp-webhook para fichar por WhatsApp.
# Generar con: node -e "console.log(require('crypto').randomUUID())"
WHATSAPP_VERIFY_TOKEN=
# Otra cadena que tú eliges — se añade como ?secret=... a la URL del webhook en
# Meta. Sin esto configurado, /api/whatsapp-webhook rechaza todas las peticiones.
# Generar con: node -e "console.log(require('crypto').randomUUID())"
WHATSAPP_WEBHOOK_SECRET=

# ── Monitoring (opcional) ─────────────────────────────────────────────────────
# DSN de Sentry para captura de errores en producción
VITE_SENTRY_DSN=
